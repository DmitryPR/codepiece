{
  "name": "codepiece-hackathon",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "next dev --turbopack -p 4000",
    "dev:fresh": "rm -rf .next && next dev --turbopack -p 4000",
    "dev:webpack": "next dev -p 4000",
    "dev:webpack:fresh": "rm -rf .next && next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "scan": "bun run src/scan/cli.ts",
    "seed:samples": "TARGET_REPO=./samples/mini-algorithms bun run src/scan/cli.ts -- --force",
    "test": "bun test",
    "test:scan": "bun test src/scan src/lib",
    "test:web": "bun test tests/web",
    "db:push": "drizzle-kit push",
    "db:stats": "bun run src/db/db-stats.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.3",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.1",
    "happy-dom": "^20.8.9",
    "typescript": "^5.7.2"
  }
}
